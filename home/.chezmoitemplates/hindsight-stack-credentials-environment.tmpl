"credentials": [
  {
    "environment": "HINDSIGHT_DATA_PLANE_TOKEN",
    "locator": "{{ .hindsight.dataPlaneLocator }}"
  },
  {
    "environment": "HINDSIGHT_MINT_AUTHORITY",
    "locator": "{{ .hindsight.mintAuthorityLocator }}"
  },
  {
    "environment": "HINDSIGHT_UI_ACCESS_KEY",
    "locator": "{{ .hindsight.uiAccessKeyLocator }}"
  }
],
"environment": {
  "HINDSIGHT_API_AUDIT_LOG_ENABLED": "false",
  "HINDSIGHT_API_LLM_TRACE_ENABLED": "false",
  "HINDSIGHT_API_TENANT_EXTENSION": "hindsight_api.extensions.builtin.tenant:ApiKeyTenantExtension",
  "HINDSIGHT_API_WORKER_ID": "{{ .hindsight.workerId }}",
  "HINDSIGHT_EMBED_API_BASE_PORT": "{{ .hindsight.apiPort }}",
  "HINDSIGHT_EMBED_AUTOSTART_DAEMON": "{{ if .hindsight.autostartDaemon }}true{{ else }}false{{ end }}",
  "HINDSIGHT_EMBED_AUTOSTART_UI": "{{ if .hindsight.autostartUi }}true{{ else }}false{{ end }}",
  "HINDSIGHT_EMBED_CONTROL_HOSTNAME": "127.0.0.1",
  "HINDSIGHT_EMBED_CONTROL_PORT": "{{ .hindsight.controlPort }}",
  "HINDSIGHT_EMBED_CONTROL_SERVER": "release://libexec/hindsight-embed-control-server.py",
  "HINDSIGHT_EMBED_DAEMON_STARTUP_TIMEOUT": "300",
  "HINDSIGHT_EMBED_FLEET_PROFILES": "{{ .hindsight.profile }}",
  "HINDSIGHT_EMBED_LLM_RUNTIME": "{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-runtime" }}",
  "HINDSIGHT_EMBED_POLL_SECONDS": "{{ .hindsight.pollSeconds }}",
  "HINDSIGHT_EMBED_PRIMARY_PROFILE": "{{ .hindsight.profile }}",
  "HINDSIGHT_EMBED_PROVIDER_PRESET_BASE_URL": "{{ .hindsight.hatcheryBaseUrl }}",
  "HINDSIGHT_EMBED_PROVIDER_PRESET_ID": "hatchery",
  "HINDSIGHT_EMBED_PROVIDER_PRESET_LABEL": "Hatchery",
  "HINDSIGHT_EMBED_PROVIDER_PRESET_MODEL": "{{ .hindsight.hatcheryModel }}",
  "HINDSIGHT_EMBED_PROVIDER_PRESET_RUNTIME_PROVIDER": "{{ .hindsight.hatcheryProvider }}",
  "HINDSIGHT_EMBED_PYTHON": "{{ joinPath .chezmoi.homeDir ".local/share/uv/tools/hindsight-embed/bin/python" }}",
  "HINDSIGHT_EMBED_STACK_LIB": "release://lib/hindsight-embed-stack.zsh",
  "HINDSIGHT_EMBED_STATE_DIR": "{{ joinPath .chezmoi.homeDir .hindsight.stateRoot "embed" }}",
  "HINDSIGHT_EMBED_STOP_HELPER": "release://libexec/hindsight-embed-stop-profile-services.py",
  "HINDSIGHT_EMBED_UI_BASE_PORT": "{{ .hindsight.uiPort }}",
  "HINDSIGHT_EMBED_UI_HOSTNAME": "{{ .hindsight.uiHostname }}",
  "HINDSIGHT_EMBED_UVX": "release://bin/hindsight-embed-uvx",
  "HINDSIGHT_MEMORY_BROKER_SOCKET": "{{ joinPath .chezmoi.homeDir .hindsight.stateRoot "memory/broker.sock" }}",
  "HINDSIGHT_MEMORY_BROKER_WAIT_SECONDS": "{{ .hindsight.memoryBrokerWaitSeconds }}",
  "HINDSIGHT_MEMORY_CLI": "release://bin/hindsight-memory",
  "HINDSIGHT_MEMORY_DATA_PLANE_TOKEN_ENV": "HINDSIGHT_DATA_PLANE_TOKEN",
  "HINDSIGHT_MEMORY_INTEGRATION_UPGRADE_STATE": "{{ joinPath .chezmoi.homeDir .hindsight.stateRoot }}",
  "HINDSIGHT_MEMORY_INVENTORY": "{{ joinPath .chezmoi.homeDir .hindsight.inventoryPath }}",
  "HINDSIGHT_MEMORY_MINT_AUTHORITY_ENV": "HINDSIGHT_MINT_AUTHORITY",
  "HINDSIGHT_MEMORY_STATE_DIR": "{{ joinPath .chezmoi.homeDir .hindsight.stateRoot "memory" }}",
  "HINDSIGHT_MEMORY_UI_ACCESS_KEY_ENV": "HINDSIGHT_UI_ACCESS_KEY",
  "HINDSIGHT_PROVIDER_POLICY_PATH": "{{ joinPath .chezmoi.homeDir .hindsight.providerPolicyPath }}",
  "HOME": "{{ .chezmoi.homeDir }}",
  "PATH": "/usr/bin:/bin:/usr/sbin:/sbin",
  "PYTHONPATH": "{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-runtime" }}"
}
