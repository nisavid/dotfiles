#!/usr/bin/env python3
"""Preserve local login setup while activating the managed Zsh profile."""

import sys


start = "# >>> secret-exec managed zprofile >>>"
end = "# <<< secret-exec managed zprofile <<<"
canonical = f"""\
{start}
function {{
  local managed_zprofile=${{ZDOTDIR:-$HOME/.config/zsh}}/zprofile.zsh
  [[ -r $managed_zprofile ]] && source $managed_zprofile
}}
{end}"""

existing = sys.stdin.read()
start_count = existing.count(start)
end_count = existing.count(end)

if start_count or end_count:
    if start_count != 1 or end_count != 1 or canonical not in existing:
        raise ValueError("managed zprofile block is partial, duplicated, or modified")
    sys.stdout.write(existing)
    raise SystemExit(0)

if not existing:
    separator = ""
elif existing.endswith("\n"):
    separator = "\n"
else:
    separator = "\n\n"

sys.stdout.write(f"{existing}{separator}{canonical}\n")
