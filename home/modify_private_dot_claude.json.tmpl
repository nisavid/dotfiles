#!/usr/bin/env bash
set -euo pipefail

command={{ joinPath .chezmoi.homeDir ".local/bin/secret-exec" | quote }}

jq --arg command "$command" '
  def local_server($existing; $args):
    (($existing // {}) + {command: $command, args: $args}) |
    del(.type, .url, .env, .env_vars, .headers, .http_headers, .bearer_token_env_var);

  .mcpServers = (.mcpServers // {}) |
  .mcpServers.context7 = local_server(.mcpServers.context7;
    ["context7", "--", "npx", "-y", "@upstash/context7-mcp@3.2.4"]) |
  .mcpServers.firecrawl = local_server(.mcpServers.firecrawl;
    ["firecrawl", "--", "npx", "-y", "firecrawl-mcp@3.22.3"]) |
  .mcpServers.github = local_server(.mcpServers.github;
    [
      "github", "--", "npx", "-y", "mcp-remote@0.1.38",
      "https://api.githubcopilot.com/mcp/", "--header",
      "Authorization:Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
    ]) |
  .mcpServers.greptile = local_server(.mcpServers.greptile;
    [
      "greptile", "--", "npx", "-y", "mcp-remote@0.1.38",
      "https://api.greptile.com/mcp", "--header",
      "Authorization:Bearer ${GREPTILE_API_KEY}"
    ])
' < /dev/stdin
