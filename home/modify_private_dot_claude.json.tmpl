#!/usr/bin/env bash
set -euo pipefail

command={{ joinPath .chezmoi.homeDir ".local/bin/secret-exec" | quote }}

jq --arg command "$command" '
  .mcpServers = (.mcpServers // {}) |
  .mcpServers.context7 = {
    command: $command,
    args: ["context7", "--", "npx", "-y", "@upstash/context7-mcp@3.2.4"]
  } |
  .mcpServers.firecrawl = {
    command: $command,
    args: ["firecrawl", "--", "npx", "-y", "firecrawl-mcp@3.22.3"]
  } |
  .mcpServers.github = {
    command: $command,
    args: [
      "github", "--", "npx", "-y", "mcp-remote@0.1.38",
      "https://api.githubcopilot.com/mcp/", "--header",
      "Authorization:Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"
    ]
  } |
  .mcpServers.greptile = {
    command: $command,
    args: [
      "greptile", "--", "npx", "-y", "mcp-remote@0.1.38",
      "https://api.greptile.com/mcp", "--header",
      "Authorization:Bearer ${GREPTILE_API_KEY}"
    ]
  }
' < /dev/stdin
