#!/usr/bin/env zsh

[[ -o xtrace ]] && unsetopt xtrace
set -euo pipefail
typeset -gr SECRET_EXEC_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}

die() {
  print -u2 -r -- "secret-exec-migrate: $1"
  exit 1
}

resolve_pass_cli() {
  emulate -L zsh

  local resolved
  resolved=$(command -v pass-cli 2>/dev/null || true)
  if [[ -n $resolved && -x $resolved ]]; then
    print -r -- "$resolved"
    return
  fi
  local candidate
  for candidate in /opt/homebrew/bin/pass-cli "$HOME/.local/bin/pass-cli"; do
    [[ -x $candidate ]] || continue
    print -r -- "$candidate"
    return
  done
  die 'pass-cli is required'
}

load_source_values() {
  emulate -L zsh

  local source=$1
  local pattern='^([A-Za-z_][A-Za-z0-9_]*)=(.+)$'
  local line name value
  while IFS= read -r line || [[ -n $line ]]; do
    [[ -z $line || $line == \#* ]] && continue
    [[ $line =~ $pattern ]] || die 'unexpected line in the ambient credential source'
    name=$match[1]
    value=${(Q)match[2]}
    [[ -n $value && $value != *$'\n'* && $value != *$'\r'* ]] || \
      die "source value for $name must be one non-empty line"
    source_values[$name]=$value
  done < "$source"

  local required
  for required in \
    AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY GITHUB_PERSONAL_ACCESS_TOKEN \
    CONTEXT7_API_KEY FIRECRAWL_API_KEY GREPTILE_API_KEY; do
    (( ${+source_values[$required]} )) || die "ambient source is missing $required"
  done
  (( ${#source_values} == 6 )) || die 'ambient source contains unexpected assignments'
}

verify_duplicate_sources() {
  emulate -L zsh
  setopt local_options extended_glob

  local zsh_source=$1
  local aws_source=$2
  local line left value name
  local in_default=0
  local -A duplicates

  [[ -r $zsh_source ]] || die 'interactive credential fragment is missing'
  while IFS='=' read -r left value || [[ -n $left ]]; do
    left=${left#export }
    left=${left//[[:space:]]/}
    [[ -z $left || $left == \#* ]] && continue
    [[ $left == [A-Za-z_][A-Za-z0-9_]* ]] || die 'interactive credential fragment has unexpected syntax'
    duplicates[$left]=${(Q)value}
  done < "$zsh_source"
  for name in GITHUB_PERSONAL_ACCESS_TOKEN CONTEXT7_API_KEY FIRECRAWL_API_KEY; do
    [[ ${duplicates[$name]:-} == "${source_values[$name]}" ]] || \
      die "interactive duplicate differs for $name"
  done
  (( ${#duplicates} == 3 )) || die 'interactive credential fragment contains unexpected assignments'

  duplicates=()
  [[ -r $aws_source ]] || die 'AWS credential duplicate is missing'
  while IFS= read -r line || [[ -n $line ]]; do
    line=${line##[[:space:]]#}
    line=${line%%[[:space:]]#}
    case $line in
      ''|'#'*|';'*) continue ;;
      '['*']')
        if [[ $line == '[default]' ]]; then
          in_default=1
        else
          in_default=0
        fi
        continue
        ;;
    esac
    (( in_default )) || continue
    [[ $line == *=* ]] || die 'AWS credential duplicate contains unexpected data'
    left=${line%%=*}
    value=${line#*=}
    left=${left//[[:space:]]/}
    value=${value//[[:space:]]/}
    case $left in
      aws_access_key_id) duplicates[AWS_ACCESS_KEY_ID]=${(Q)value} ;;
      aws_secret_access_key) duplicates[AWS_SECRET_ACCESS_KEY]=${(Q)value} ;;
      *) die 'AWS credential duplicate contains unexpected data' ;;
    esac
  done < "$aws_source"
  for name in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY; do
    [[ ${duplicates[$name]:-} == "${source_values[$name]}" ]] || \
      die "AWS duplicate differs for $name"
  done
  (( ${#duplicates} == 2 )) || die 'AWS credential duplicate is incomplete'
}

create_login_item() {
  emulate -L zsh
  setopt local_options pipe_fail

  local backend=$1
  local title=$2
  local username=$3
  local password=$4
  {
    print -rn -- "$title"$'\0'"$username"$'\0'"$password"$'\0'
  } | python3 -c '
import json, sys
parts = sys.stdin.buffer.read().split(b"\0")
if len(parts) != 4 or parts[-1]:
    raise SystemExit("invalid migration payload")
title, username, password = (part.decode() for part in parts[:3])
json.dump({
    "title": title,
    "username": username or None,
    "email": None,
    "password": password,
    "totp_uri": None,
    "urls": [],
}, sys.stdout)
' | "$backend" item create login --from-template - --vault-name cli-secrets > /dev/null
}

reference_value() {
  emulate -L zsh

  local backend=$1
  local reference=$2
  local value
  value=$("$backend" item view --output human "$reference") || return 1
  [[ -n $value && $value != *$'\n'* && $value != *$'\r'* ]] || return 1
  print -r -- "$value"
}

ensure_vault() {
  emulate -L zsh

  local backend=$1
  local vaults
  vaults=$("$backend" vault list --output json) || die 'cannot list Proton Pass vaults'
  if ! print -r -- "$vaults" | jq -e '.vaults[]? | select(.name == "cli-secrets")' > /dev/null; then
    "$backend" vault create --name cli-secrets > /dev/null || die 'cannot create cli-secrets vault'
  fi
}

ensure_item() {
  emulate -L zsh

  local backend=$1
  local title=$2
  local username=$3
  local password=$4
  local items
  items=$("$backend" item list --vault-name cli-secrets --output json) || \
    die 'cannot list cli-secrets items'
  if ! print -r -- "$items" | jq -e --arg title "$title" \
    '.items[]? | select(.title == $title)' > /dev/null; then
    create_login_item "$backend" "$title" "$username" "$password" || \
      die "cannot create Proton item $title"
    print -r -- "imported $title"
  fi
}

verify_reference() {
  emulate -L zsh

  local backend=$1
  local name=$2
  local reference=$3
  local expected=${4-}
  local actual
  actual=$(reference_value "$backend" "$reference") || die "cannot resolve Proton reference for $name"
  if (( $# == 4 )); then
    [[ $actual == "$expected" ]] || die "Proton item differs for $name"
  fi
  print -r -- "verified $name"
}

require_regular_file() {
  emulate -L zsh

  local file=$1
  local label=$2
  [[ -f $file && ! -L $file && -r $file ]] || \
    die "$label must be a readable regular file before retirement"
}

validate_retirement_readiness() {
  emulate -L zsh
  setopt local_options pipe_fail

  local have_source=$1
  local launcher=$HOME/.local/bin/secret-exec
  local profile_dir=$SECRET_EXEC_CONFIG_HOME/secret-exec/profiles
  local codex_config=$HOME/.codex/config.toml
  local claude_config=$HOME/.claude.json
  local claude_settings=$HOME/.claude/settings.json
  local aws_config=$HOME/.aws/config
  local mcp_config=$SECRET_EXEC_CONFIG_HOME/mcp-config.json
  local opencode_config=$SECRET_EXEC_CONFIG_HOME/opencode/opencode.json
  local zsh_loader=$SECRET_EXEC_CONFIG_HOME/zsh/zshenv.zsh
  local zsh_entry=$HOME/.zshenv

  [[ -x $launcher && ! -L $launcher ]] || die 'secret-exec must be an executable regular file before retirement'
  require_regular_file "$codex_config" 'Codex config'
  require_regular_file "$claude_config" 'Claude config'
  require_regular_file "$claude_settings" 'Claude settings'
  require_regular_file "$aws_config" 'AWS config'
  require_regular_file "$mcp_config" 'generic MCP config'
  require_regular_file "$zsh_loader" 'Zsh environment loader'
  [[ -L $zsh_entry && ${zsh_entry:A} == "${zsh_loader:A}" ]] || \
    die 'the Zsh startup entry point must resolve to the managed environment loader'
  grep -Fxq '# secret-exec-environment-loader-v1' "$zsh_loader" || \
    die 'the hardened Zsh environment loader is not active'

  local -a expected profile_files
  expected=(
    aws.env $'AWS_ACCESS_KEY_ID=pass://cli-secrets/aws/username\nAWS_SECRET_ACCESS_KEY=pass://cli-secrets/aws/password'
    context7.env 'CONTEXT7_API_KEY=pass://cli-secrets/context7/password'
    firecrawl.env 'FIRECRAWL_API_KEY=pass://cli-secrets/firecrawl/password'
    github.env 'GITHUB_PERSONAL_ACCESS_TOKEN=pass://cli-secrets/github-mcp/password'
    greptile.env 'GREPTILE_API_KEY=pass://cli-secrets/greptile/password'
  )
  local profile_file profile_value
  integer index=1
  while (( index <= ${#expected} )); do
    profile_file=$profile_dir/$expected[$index]
    profile_value=$expected[$(( index + 1 ))]
    require_regular_file "$profile_file" "secret-exec profile ${profile_file:t}"
    [[ $(<"$profile_file") == "$profile_value" ]] || \
      die "secret-exec profile ${profile_file:t} does not match the canonical contract"
    (( index += 2 ))
  done
  profile_files=("$profile_dir"/*.env(N.))
  (( ${#profile_files} == 5 )) || \
    die 'secret-exec profile directory contains an unexpected file set'

  local codex_cli codex_servers
  codex_cli=$(command -v codex 2>/dev/null) || die 'codex is required to validate its MCP configuration'
  codex_servers=$("$codex_cli" mcp list --json 2>/dev/null) || die 'cannot read the effective Codex MCP configuration'
  print -r -- "$codex_servers" | jq -e --arg command "$launcher" '
    def transport($name): map(select(.name == $name))[0].transport;
    (transport("context7") |
      .type == "stdio" and .command == $command and
      .args == ["context7", "--", "npx", "-y", "@upstash/context7-mcp@3.2.4"] and
      ((.env // {}) | length) == 0 and ((.env_vars // []) | length) == 0) and
    (transport("firecrawl") |
      .type == "stdio" and .command == $command and
      .args == ["firecrawl", "--", "npx", "-y", "firecrawl-mcp@3.22.3"] and
      ((.env // {}) | length) == 0 and ((.env_vars // []) | length) == 0) and
    (transport("github") |
      .type == "stdio" and .command == $command and
      .args == ["github", "--", "npx", "-y", "mcp-remote@0.1.38",
        "https://api.githubcopilot.com/mcp/", "--header",
        "Authorization:Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"] and
      ((.env // {}) | length) == 0 and ((.env_vars // []) | length) == 0)
  ' > /dev/null || die 'effective Codex MCP bindings do not match the canonical contract'

  jq -e --arg command "$launcher" '
    .mcpServers.context7 == {
      command: $command, args: ["context7", "--", "npx", "-y", "@upstash/context7-mcp@3.2.4"]
    } and
    .mcpServers.firecrawl == {
      command: $command, args: ["firecrawl", "--", "npx", "-y", "firecrawl-mcp@3.22.3"]
    } and
    .mcpServers.github == {
      command: $command, args: ["github", "--", "npx", "-y", "mcp-remote@0.1.38",
        "https://api.githubcopilot.com/mcp/", "--header",
        "Authorization:Bearer ${GITHUB_PERSONAL_ACCESS_TOKEN}"]
    } and
    .mcpServers.greptile == {
      command: $command, args: ["greptile", "--", "npx", "-y", "mcp-remote@0.1.38",
        "https://api.greptile.com/mcp", "--header",
        "Authorization:Bearer ${GREPTILE_API_KEY}"]
    }
  ' "$claude_config" > /dev/null || die 'Claude MCP bindings do not match the canonical contract'
  jq -e '
    .enabledPlugins["context7@claude-plugins-official"] == false and
    .enabledPlugins["github@claude-plugins-official"] == false and
    .enabledPlugins["greptile@claude-plugins-official"] == false
  ' "$claude_settings" > /dev/null || die 'credential-dependent Claude plugin MCPs are still enabled'
  jq -e --arg command "$launcher" '
    .mcpServers.firecrawl as $server |
    $server.type == "stdio" and
    $server.command == $command and
    $server.args == ["firecrawl", "--", "npx", "-y", "firecrawl-mcp@3.22.3"] and
    (["url", "env", "env_vars", "headers", "http_headers", "bearer_token_env_var"] |
      all(. as $field | ($server | has($field) | not)))
  ' "$mcp_config" > /dev/null || die 'generic Firecrawl MCP binding does not match the canonical contract'

  if [[ -e $opencode_config || -L $opencode_config ]]; then
    require_regular_file "$opencode_config" 'OpenCode config'
    jq -e --arg command "$launcher" '
      .mcp.context7 as $server |
      $server.type == "local" and
      $server.command == [$command, "context7", "--", "npx", "-y", "@upstash/context7-mcp@3.2.4"] and
      ($server.enabled | type) == "boolean" and
      (["url", "env", "env_vars", "headers", "http_headers", "bearer_token_env_var"] |
        all(. as $field | ($server | has($field) | not)))
    ' "$opencode_config" > /dev/null || \
      die 'OpenCode Context7 binding does not match the canonical process-scoped contract'
  fi

  local candidate
  local ambient_pattern='^[[:space:]]*(export[[:space:]]+)?(AWS_ACCESS_KEY_ID|AWS_SECRET_ACCESS_KEY|AWS_SESSION_TOKEN|GITHUB_PERSONAL_ACCESS_TOKEN|CONTEXT7_API_KEY|FIRECRAWL_API_KEY|GREPTILE_API_KEY|CODEX_GITHUB_PAT|FOSSA_API_KEY)='
  for candidate in \
    "$SECRET_EXEC_CONFIG_HOME"/environment.d/*.conf(N.) \
    "$SECRET_EXEC_CONFIG_HOME"/zsh/zshrc.d/*.zsh(N.); do
    [[ $candidate == "$SECRET_EXEC_CONFIG_HOME/environment.d/10-apikeys.local.conf" ||
      $candidate == "$SECRET_EXEC_CONFIG_HOME/zsh/zshrc.d/apikeys.local.zsh" ]] && continue
    if grep -Eq "$ambient_pattern" "$candidate"; then
      die "unexpected ambient credential source remains: $candidate"
    fi
  done
  [[ ! -e $SECRET_EXEC_CONFIG_HOME/firecrawl-cli/credentials.json ]] || \
    die 'stale Firecrawl CLI credential file remains'

  awk -v expected="credential_process = $launcher aws-credential-process aws" '
    /^\[[^]]+\]$/ {
      in_default = ($0 == "[default]")
      saw_default = saw_default || in_default
      next
    }
    in_default && /^[[:space:]]*(login_session|aws_access_key_id|aws_secret_access_key|aws_session_token)[[:space:]]*=/ {
      exit 1
    }
    in_default && /^[[:space:]]*credential_process[[:space:]]*=/ {
      if ($0 != expected) exit 1
      process_count++
    }
    END { if (!saw_default || process_count != 1) exit 1 }
  ' "$aws_config" || die 'default AWS binding does not match the canonical credential-process contract'

  if (( have_source )); then
    local -a consumers
    consumers=(
      "$codex_config" "$claude_config" "$claude_settings" "$aws_config" "$mcp_config"
      "$zsh_loader" "$profile_dir"/*.env(N.) "$opencode_config"(N.)
    )
    {
      local name
      for name in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY GITHUB_PERSONAL_ACCESS_TOKEN \
        CONTEXT7_API_KEY FIRECRAWL_API_KEY GREPTILE_API_KEY; do
        print -rn -- "$source_values[$name]"$'\0'
      done
    } | python3 -c '
import pathlib, sys
parts = sys.stdin.buffer.read().split(b"\0")
if not parts or parts[-1]:
    raise SystemExit(2)
values = parts[:-1]
blob = b"".join(pathlib.Path(path).read_bytes() for path in sys.argv[1:])
raise SystemExit(any(value in blob for value in values))
' "${consumers[@]}" || die 'a managed consumer still contains a legacy credential value'
  fi
}

main() {
  emulate -L zsh
  setopt local_options extended_glob pipe_fail

  local retire=0
  if (( $# )); then
    [[ $# == 1 && $1 == --retire-plaintext ]] || \
      die 'usage: secret-exec-migrate [--retire-plaintext]'
    retire=1
  fi

  local environment_source=$SECRET_EXEC_CONFIG_HOME/environment.d/10-apikeys.local.conf
  local zsh_source=$SECRET_EXEC_CONFIG_HOME/zsh/zshrc.d/apikeys.local.zsh
  local aws_source=$HOME/.aws/credentials
  local mcp_source=$SECRET_EXEC_CONFIG_HOME/mcp-config.json
  local backend
  backend=$(resolve_pass_cli)
  typeset -gA source_values
  source_values=()

  local have_source=0
  local legacy_source_count=0
  local legacy_path
  for legacy_path in "$environment_source" "$zsh_source" "$aws_source"; do
    [[ -e $legacy_path || -L $legacy_path ]] && (( ++legacy_source_count ))
  done
  (( legacy_source_count == 0 || legacy_source_count == 3 )) || \
    die 'legacy credential sources are incomplete; refusing to continue'

  if (( legacy_source_count == 3 )); then
    for legacy_path in "$environment_source" "$zsh_source" "$aws_source"; do
      [[ -f $legacy_path && ! -L $legacy_path && -r $legacy_path ]] || \
        die 'legacy credential sources must be readable regular files'
    done
    have_source=1
    load_source_values "$environment_source"
    verify_duplicate_sources "$zsh_source" "$aws_source"
    ensure_vault "$backend"
    ensure_item "$backend" aws \
      "$source_values[AWS_ACCESS_KEY_ID]" "$source_values[AWS_SECRET_ACCESS_KEY]"
    ensure_item "$backend" github-mcp '' "$source_values[GITHUB_PERSONAL_ACCESS_TOKEN]"
    ensure_item "$backend" context7 '' "$source_values[CONTEXT7_API_KEY]"
    ensure_item "$backend" firecrawl '' "$source_values[FIRECRAWL_API_KEY]"
    ensure_item "$backend" greptile '' "$source_values[GREPTILE_API_KEY]"
  fi

  local -A references
  references=(
    AWS_ACCESS_KEY_ID pass://cli-secrets/aws/username
    AWS_SECRET_ACCESS_KEY pass://cli-secrets/aws/password
    GITHUB_PERSONAL_ACCESS_TOKEN pass://cli-secrets/github-mcp/password
    CONTEXT7_API_KEY pass://cli-secrets/context7/password
    FIRECRAWL_API_KEY pass://cli-secrets/firecrawl/password
    GREPTILE_API_KEY pass://cli-secrets/greptile/password
  )
  local name
  for name in AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY GITHUB_PERSONAL_ACCESS_TOKEN \
    CONTEXT7_API_KEY FIRECRAWL_API_KEY GREPTILE_API_KEY; do
    if (( have_source )); then
      verify_reference "$backend" "$name" "$references[$name]" "$source_values[$name]"
    else
      verify_reference "$backend" "$name" "$references[$name]"
    fi
  done

  if (( ! retire )); then
    return 0
  fi
  validate_retirement_readiness "$have_source"
  if (( have_source )); then
    rm -f -- "$environment_source" "$zsh_source" "$aws_source" || \
      die 'failed to remove one or more plaintext credential files'
    print -r -- 'retired plaintext credential files'
  fi
}

main "$@"
