#!/usr/bin/env zsh

[[ -o xtrace ]] && unsetopt xtrace
set -euo pipefail

die() {
  print -u2 -r -- "secret-exec: $1"
  exit 1
}

resolve_pass_cli() {
  emulate -L zsh

  local resolved
  resolved=$(command -v pass-cli 2>/dev/null || true)
  if [[ -n $resolved && -x $resolved ]]; then
    print -r -- "$resolved"
    return
  fi

  local candidate
  for candidate in /opt/homebrew/bin/pass-cli "$HOME/.local/bin/pass-cli"; do
    if [[ -x $candidate ]]; then
      print -r -- "$candidate"
      return
    fi
  done

  die 'pass-cli is required'
}

load_profiles() {
  emulate -L zsh
  setopt local_options extended_glob

  local profile_dir=$1
  local selected_profile=$2
  local mapping_pattern='^([A-Za-z_][A-Za-z0-9_]*)=(pass://[^[:space:]]+)$'
  local file profile line name reference key
  local -a files

  files=("$profile_dir"/*.env(N.))
  (( ${#files} )) || die "no profiles found in $profile_dir"

  for file in "${files[@]}"; do
    [[ ! -L $file ]] || die "profile must not be a symbolic link: ${file:t}"
    profile=${file:t:r}
    [[ $profile == [A-Za-z0-9][A-Za-z0-9_.-]# ]] || \
      die "invalid profile name: $profile"

    while IFS= read -r line || [[ -n $line ]]; do
      [[ -z $line || $line == \#* ]] && continue
      [[ $line =~ $mapping_pattern ]] || die "invalid mapping in ${file:t}"
      name=$match[1]
      reference=$match[2]
      key=$profile:$name
      (( ! ${+profile_references[$key]} )) || \
        die "duplicate mapping for $name in $profile"
      profile_references[$key]=$reference
      managed_names[$name]=1
      [[ $profile == $selected_profile ]] && selected_references[$name]=$reference
    done < "$file"
  done

  (( ${#selected_references} )) || die "unknown or empty profile: $selected_profile"
}

scrub_managed_environment() {
  emulate -L zsh

  local name
  for name in "${(k)managed_names[@]}"; do
    unset "$name"
  done
}

resolve_selected_secrets() {
  emulate -L zsh

  local backend=$1
  local name reference secret
  for name in "${(k)selected_references[@]}"; do
    reference=$selected_references[$name]
    secret=$("$backend" item view "$reference") || \
      die "failed to resolve $name"
    [[ -n $secret && $secret != *$'\n'* && $secret != *$'\r'* ]] || \
      die "resolved value for $name must be one non-empty line"
    export "$name=$secret"
  done
}

emit_aws_credentials() {
  emulate -L zsh
  setopt local_options extended_glob

  (( ${#selected_references} == 2 )) || \
    die 'AWS profile must contain exactly two mappings'
  (( ${+selected_references[AWS_ACCESS_KEY_ID]} )) || \
    die 'AWS profile is missing AWS_ACCESS_KEY_ID'
  (( ${+selected_references[AWS_SECRET_ACCESS_KEY]} )) || \
    die 'AWS profile is missing AWS_SECRET_ACCESS_KEY'
  [[ ! -t 1 ]] || die 'refusing to write AWS credentials to a terminal'
  [[ $AWS_ACCESS_KEY_ID == [A-Z0-9]## ]] || \
    die 'AWS access key has an invalid format'
  [[ $AWS_SECRET_ACCESS_KEY == [A-Za-z0-9/+=]## ]] || \
    die 'AWS secret key has an invalid format'

  print -r -- \
    '{"Version":1,"AccessKeyId":"'${AWS_ACCESS_KEY_ID}'","SecretAccessKey":"'${AWS_SECRET_ACCESS_KEY}'"}'
}

main() {
  emulate -L zsh
  setopt local_options extended_glob pipe_fail

  (( $# )) || die 'usage: secret-exec <profile> -- <command> [args...] | secret-exec aws-credential-process <profile>'

  local mode=exec
  local profile
  if [[ $1 == aws-credential-process ]]; then
    mode=aws
    (( $# == 2 )) || die 'usage: secret-exec aws-credential-process <profile>'
    profile=$2
  else
    profile=$1
    shift
    [[ ${1:-} == -- ]] || die 'expected -- before the command'
    shift
    (( $# )) || die 'a target command is required'
  fi

  local profile_dir=${XDG_CONFIG_HOME:-$HOME/.config}/secret-exec/profiles
  local backend
  typeset -gA profile_references managed_names selected_references
  profile_references=()
  managed_names=()
  selected_references=()

  load_profiles "$profile_dir" "$profile"
  scrub_managed_environment
  backend=$(resolve_pass_cli)
  resolve_selected_secrets "$backend"

  if [[ $mode == aws ]]; then
    emit_aws_credentials
    return
  fi

  exec "$@"
}

main "$@"
