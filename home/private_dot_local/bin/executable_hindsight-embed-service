#!/usr/bin/env zsh
set -euo pipefail

STACK_LABEL="com.hindsight.embed.stack"
LEGACY_LABEL="com.hindsight.embed.control"
PLIST="${HOME}/Library/LaunchAgents/${STACK_LABEL}.plist"
LEGACY_PLIST="${HOME}/Library/LaunchAgents/${LEGACY_LABEL}.plist"
SUPERVISOR="${HOME}/.local/bin/hindsight-embed-supervisor"
STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-$HOME/.local/lib/hindsight-embed-stack.zsh}"
STATE_DIR="${HINDSIGHT_EMBED_STATE_DIR:-${HOME}/.local/state/hindsight-embed-launchd}"
LOG_FILE="${STATE_DIR}/logs/supervisor.log"
typeset -g HINDSIGHT_EMBED_STACK_LIB_LOADED=0

usage() {
  cat <<EOF
Usage: hindsight-embed-service <command>

Commands:
  install   Validate, retire legacy launchd state, and load the LaunchAgent
  auth-refresh
            Refresh Codex login for Hindsight and restart the managed stack
  start     Load or restart the LaunchAgent for this user
  stop      Unload the LaunchAgent and stop control, API, and UI
  status    Show launchd and stack health
  logs      Tail the supervisor log
EOF
}

die() {
  print -ru2 -- "hindsight-embed-service: $*"
  exit 1
}

load_stack_lib() {
  emulate -L zsh

  if (( HINDSIGHT_EMBED_STACK_LIB_LOADED )); then
    return 0
  fi
  [[ -r "$STACK_LIB" ]] || {
    print -ru2 -- "hindsight-embed-service: missing stack library at ${STACK_LIB}"
    return 1
  }
  . "$STACK_LIB" || {
    print -ru2 -- "hindsight-embed-service: failed to source stack library at ${STACK_LIB}"
    return 1
  }
  local required_function
  for required_function in \
    hindsight_stack_log \
    hindsight_stack_load_config \
    hindsight_stack_reconcile_once \
    hindsight_stack_require_current_user \
    hindsight_stack_profile_exists \
    hindsight_stack_require_profile \
    hindsight_stack_require_tools \
    hindsight_stack_require_runtime_helpers \
    hindsight_stack_start_all \
    hindsight_stack_status_report \
    hindsight_stack_stop_all \
    hindsight_stack_wait_all \
    hindsight_stack_wait_stopped_for; do
    if (( ! ${+functions[$required_function]} )); then
      print -ru2 -- "hindsight-embed-service: invalid stack library at ${STACK_LIB}; missing ${required_function}"
      return 1
    fi
  done
  typeset -g HINDSIGHT_EMBED_STACK_LIB_LOADED=1
}

domain() {
  emulate -L zsh
  print -r -- "gui/${UID}"
}

service_name() {
  emulate -L zsh
  local label="$1"
  print -r -- "$(domain)/${label}"
}

is_loaded() {
  emulate -L zsh
  local label="$1"
  /bin/launchctl print "$(service_name "$label")" >/dev/null 2>&1
}

has_disabled_override() {
  emulate -L zsh
  local label="$1"
  /bin/launchctl print-disabled "$(domain)" 2>/dev/null \
    | /usr/bin/grep -F "\"${label}\" =>" \
    | /usr/bin/grep -E "=>[[:space:]]*(true|disabled)" >/dev/null 2>&1
}

bootout_if_loaded() {
  emulate -L zsh
  local label="$1"

  if is_loaded "$label"; then
    /bin/launchctl bootout "$(service_name "$label")" || return 1
    print -r -- "${label} unloaded for this login session"
  fi
}

retire_legacy_plist() {
  emulate -L zsh
  [[ -e "$LEGACY_PLIST" ]] || return 0
  [[ ! -L "$LEGACY_PLIST" ]] || die "refusing symlinked legacy plist at ${LEGACY_PLIST}"

  local legacy_dir="${STATE_DIR}/legacy"
  local archive="${legacy_dir}/${LEGACY_LABEL}.$(/bin/date -u +%Y%m%dT%H%M%SZ).plist"
  mkdir -p "$legacy_dir" || die "failed to create legacy archive directory: ${legacy_dir}"
  /bin/mv "$LEGACY_PLIST" "$archive" || die "failed to archive legacy plist at ${LEGACY_PLIST}"
  print -r -- "legacy plist archived: ${archive}"
}

validate_installed_files() {
  emulate -L zsh
  hindsight_stack_load_config

  [[ -f "$PLIST" ]] || die "missing plist at ${PLIST}; run chezmoi apply for this target first"
  [[ ! -L "$PLIST" ]] || die "refusing symlinked plist at ${PLIST}"
  [[ -x "$SUPERVISOR" ]] || die "missing executable supervisor at ${SUPERVISOR}"
  [[ -r "$STACK_LIB" ]] || die "missing stack library at ${STACK_LIB}"
  [[ -x "$HINDSIGHT_EMBED_UVX" ]] || die "uvx is not executable at ${HINDSIGHT_EMBED_UVX}"
  hindsight_stack_require_runtime_helpers || die "Hindsight helper runtime failed validation"
  hindsight_stack_require_profile || die "configured Hindsight profile preflight failed"
  /usr/bin/plutil -lint "$PLIST" >/dev/null || die "plist failed lint: ${PLIST}"
}

validate_launchd_state() {
  emulate -L zsh
  if has_disabled_override "$STACK_LABEL"; then
    die "launchd has a disabled override for ${STACK_LABEL}; clear it explicitly before starting"
  fi
}

show_installed_file_checks() {
  emulate -L zsh
  local ok=0
  local stack_loaded=0
  local uvx="${HINDSIGHT_EMBED_UVX:-$HOME/.local/bin/uvx}"

  if load_stack_lib >/dev/null 2>&1; then
    stack_loaded=1
    hindsight_stack_load_config
    uvx="$HINDSIGHT_EMBED_UVX"
  fi

  print -r -- "installed files:"

  if [[ -f "$PLIST" && ! -L "$PLIST" ]]; then
    print -r -- "  plist: ok (${PLIST})"
    if /usr/bin/plutil -lint "$PLIST" >/dev/null 2>&1; then
      print -r -- "  plist lint: ok"
    else
      print -r -- "  plist lint: failed"
      ok=1
    fi
  else
    print -r -- "  plist: missing or symlinked (${PLIST})"
    ok=1
  fi

  if [[ -x "$SUPERVISOR" ]]; then
    print -r -- "  supervisor: ok (${SUPERVISOR})"
  else
    print -r -- "  supervisor: missing or not executable (${SUPERVISOR})"
    ok=1
  fi

  if (( stack_loaded )); then
    print -r -- "  stack library: ok (${STACK_LIB})"
  elif [[ -r "$STACK_LIB" ]]; then
    print -r -- "  stack library: failed to load or invalid (${STACK_LIB})"
    ok=1
  else
    print -r -- "  stack library: missing (${STACK_LIB})"
    ok=1
  fi

  if [[ -x "$uvx" ]]; then
    print -r -- "  uvx: ok (${uvx})"
  else
    print -r -- "  uvx: missing or not executable (${uvx})"
    ok=1
  fi

  if (( stack_loaded )) && hindsight_stack_require_runtime_helpers >/dev/null 2>&1; then
    print -r -- "  helper runtime: ok"
  else
    print -r -- "  helper runtime: failed"
    ok=1
  fi

  if (( stack_loaded )) && hindsight_stack_profile_exists; then
    print -r -- "  configured profile: ok (${HINDSIGHT_EMBED_PROFILE})"
  else
    print -r -- "  configured profile: missing (${HINDSIGHT_EMBED_PROFILE:-unknown})"
    ok=1
  fi

  return "$ok"
}

preflight_launchd_service() {
  emulate -L zsh
  hindsight_stack_require_current_user || exit 1
  validate_installed_files
  validate_launchd_state
  mkdir -p "${STATE_DIR}/logs" || die "failed to create log directory: ${STATE_DIR}/logs"
}

load_launchd_service() {
  emulate -L zsh

  if is_loaded "$STACK_LABEL"; then
    /bin/launchctl kickstart -k "$(service_name "$STACK_LABEL")" ||
      die "failed to restart ${STACK_LABEL}"
  else
    /bin/launchctl bootstrap "$(domain)" "$PLIST" ||
      die "failed to load ${STACK_LABEL} from ${PLIST}"
  fi
  is_loaded "$STACK_LABEL" || die "${STACK_LABEL} is not loaded after launchctl operation"

  if hindsight_stack_wait_all; then
    print -r -- "${STACK_LABEL} is loaded and Hindsight stack is healthy"
  else
    die "${STACK_LABEL} loaded, but Hindsight stack did not become healthy; see ${LOG_FILE}"
  fi
}

start_launchd_service() {
  emulate -L zsh

  preflight_launchd_service
  load_launchd_service
}

install_service() {
  emulate -L zsh

  preflight_launchd_service
  bootout_if_loaded "$LEGACY_LABEL" || die "failed to unload ${LEGACY_LABEL}"
  load_launchd_service
  retire_legacy_plist
}

hindsight_codex_home() {
  emulate -L zsh
  hindsight_stack_load_config

  local profile_file="$HOME/.hindsight/profiles/${HINDSIGHT_EMBED_PROFILE}.env"
  local line codex_home
  while IFS= read -r line; do
    [[ "$line" == CODEX_HOME=* ]] || continue
    codex_home="${line#CODEX_HOME=}"
    [[ "$codex_home" == /* ]] || {
      print -ru2 -- "hindsight-embed-service: ${profile_file} must set CODEX_HOME to an absolute path"
      return 1
    }
    print -r -- "$codex_home"
    return 0
  done < "$profile_file"

  print -ru2 -- "hindsight-embed-service: ${profile_file} does not set CODEX_HOME"
  return 1
}

refresh_codex_auth() {
  emulate -L zsh
  hindsight_stack_require_current_user || exit 1
  hindsight_stack_require_profile || die "configured Hindsight profile preflight failed"

  local codex="${HINDSIGHT_EMBED_CODEX:-}"
  if [[ -z "$codex" ]]; then
    codex="$(command -v codex 2>/dev/null)" || die "Codex CLI is not installed"
  fi
  [[ -x "$codex" ]] || die "Codex CLI is not executable at ${codex}"

  local codex_home
  codex_home="$(hindsight_codex_home)" || die "failed to read Hindsight Codex credential path"

  print -r -- "Refreshing Codex login for Hindsight profile ${HINDSIGHT_EMBED_PROFILE}"
  CODEX_HOME="$codex_home" "$codex" login || die "Codex login failed; Hindsight was not restarted"
  CODEX_HOME="$codex_home" "$codex" login status >/dev/null ||
    die "Codex login verification failed; Hindsight was not restarted"

  print -r -- "Codex login refreshed; restarting the managed Hindsight stack"
  if [[ -n "${HINDSIGHT_EMBED_SERVICE:-}" ]]; then
    [[ -x "$HINDSIGHT_EMBED_SERVICE" ]] ||
      die "managed service command is not executable at ${HINDSIGHT_EMBED_SERVICE}"
    "$HINDSIGHT_EMBED_SERVICE" stop
    "$HINDSIGHT_EMBED_SERVICE" start
  else
    bootout_if_loaded "$STACK_LABEL" || die "failed to unload ${STACK_LABEL}"
    hindsight_stack_stop_all || die "failed to stop Hindsight stack after Codex login"
    start_launchd_service
  fi
}

stop_service() {
  emulate -L zsh
  if (( EUID == 0 || UID == 0 )); then
    die "refusing to run as root"
  fi

  bootout_if_loaded "$STACK_LABEL" || die "failed to unload ${STACK_LABEL}"

  load_stack_lib ||
    die "launchd unloaded, but stack cleanup could not run because the stack library failed to load"
  hindsight_stack_load_config
  if hindsight_stack_wait_stopped_for ui "$HINDSIGHT_EMBED_STOP_WAIT_SECONDS" &&
    hindsight_stack_wait_stopped_for daemon "$HINDSIGHT_EMBED_STOP_WAIT_SECONDS" &&
    hindsight_stack_wait_stopped_for control "$HINDSIGHT_EMBED_STOP_WAIT_SECONDS"; then
    return 0
  fi
  hindsight_stack_stop_all || die "failed to stop Hindsight stack"
}

show_status() {
  emulate -L zsh
  if (( EUID == 0 || UID == 0 )); then
    die "refusing to run as root"
  fi
  local install_ok=0

  if is_loaded "$STACK_LABEL"; then
    print -r -- "launchd: loaded ($(service_name "$STACK_LABEL"))"
  else
    print -r -- "launchd: not loaded ($(service_name "$STACK_LABEL"))"
  fi

  if has_disabled_override "$STACK_LABEL"; then
    print -r -- "disabled override: true"
  else
    print -r -- "disabled override: false"
  fi

  print -r -- ""
  show_installed_file_checks || install_ok=1

  print -r -- ""
  if (( install_ok == 0 && HINDSIGHT_EMBED_STACK_LIB_LOADED )); then
    hindsight_stack_status_report
  else
    print -r -- "stack health: unavailable (install or runtime checks failed)"
  fi

  return "$install_ok"
}

show_logs() {
  emulate -L zsh
  mkdir -p "${STATE_DIR}/logs" || die "failed to create log directory: ${STATE_DIR}/logs"
  touch "$LOG_FILE" || die "failed to open log file: ${LOG_FILE}"
  tail -n 80 -f "$LOG_FILE"
}

main() {
  emulate -L zsh
  setopt pipe_fail no_unset

  local command="${1:-}"

  case "$command" in
    install)
      load_stack_lib || exit 1
      install_service
      ;;
    auth-refresh)
      load_stack_lib || exit 1
      refresh_codex_auth
      ;;
    start)
      load_stack_lib || exit 1
      start_launchd_service
      ;;
    stop)
      stop_service
      ;;
    status)
      show_status
      ;;
    logs)
      show_logs
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      usage >&2
      die "unknown command: ${command}"
      ;;
  esac
}

main "$@"
