#!/usr/bin/env zsh
set -euo pipefail

STACK_LABEL="com.hindsight.embed.stack"
LEGACY_LABEL="com.hindsight.embed.control"
PLIST="${HOME}/Library/LaunchAgents/${STACK_LABEL}.plist"
LEGACY_PLIST="${HOME}/Library/LaunchAgents/${LEGACY_LABEL}.plist"
SUPERVISOR="${HOME}/.local/bin/hindsight-embed-supervisor"
STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-$HOME/.local/lib/hindsight-embed-stack.zsh}"
STATE_DIR="${HINDSIGHT_EMBED_STATE_DIR:-${HOME}/.local/state/hindsight-embed-launchd}"
LOG_FILE="${STATE_DIR}/logs/supervisor.log"

[[ -r "$STACK_LIB" ]] || {
  print -ru2 -- "hindsight-embed-service: missing stack library at ${STACK_LIB}"
  exit 1
}
. "$STACK_LIB"

usage() {
  cat <<EOF
Usage: hindsight-embed-service <command>

Commands:
  install   Validate the installed LaunchAgent and load it for this user
  start     Load or restart the LaunchAgent for this user
  stop      Unload the LaunchAgent and stop control, API, and UI
  status    Show launchd and stack health
  logs      Tail the supervisor log
EOF
}

die() {
  print -ru2 -- "hindsight-embed-service: $*"
  exit 1
}

domain() {
  emulate -L zsh
  print -r -- "gui/${UID}"
}

service_name() {
  emulate -L zsh
  local label="$1"
  print -r -- "$(domain)/${label}"
}

is_loaded() {
  emulate -L zsh
  local label="$1"
  /bin/launchctl print "$(service_name "$label")" >/dev/null 2>&1
}

has_disabled_override() {
  emulate -L zsh
  local label="$1"
  /bin/launchctl print-disabled "$(domain)" 2>/dev/null \
    | /usr/bin/grep -F "\"${label}\" => true" >/dev/null 2>&1
}

bootout_if_loaded() {
  emulate -L zsh
  local label="$1"

  if is_loaded "$label"; then
    /bin/launchctl bootout "$(service_name "$label")" || return 1
    print -r -- "${label} unloaded for this login session"
  fi
}

retire_legacy_plist() {
  emulate -L zsh
  [[ -e "$LEGACY_PLIST" ]] || return 0
  [[ ! -L "$LEGACY_PLIST" ]] || die "refusing symlinked legacy plist at ${LEGACY_PLIST}"

  local legacy_dir="${STATE_DIR}/legacy"
  local archive="${legacy_dir}/${LEGACY_LABEL}.$(/bin/date -u +%Y%m%dT%H%M%SZ).plist"
  mkdir -p "$legacy_dir" || die "failed to create legacy archive directory: ${legacy_dir}"
  /bin/mv "$LEGACY_PLIST" "$archive" || die "failed to archive legacy plist at ${LEGACY_PLIST}"
  print -r -- "legacy plist archived: ${archive}"
}

validate_installed_files() {
  emulate -L zsh
  hindsight_stack_load_config

  [[ -f "$PLIST" ]] || die "missing plist at ${PLIST}; run chezmoi apply for this target first"
  [[ ! -L "$PLIST" ]] || die "refusing symlinked plist at ${PLIST}"
  [[ -x "$SUPERVISOR" ]] || die "missing executable supervisor at ${SUPERVISOR}"
  [[ -r "$STACK_LIB" ]] || die "missing stack library at ${STACK_LIB}"
  [[ -x "$HINDSIGHT_EMBED_UVX" ]] || die "uvx is not executable at ${HINDSIGHT_EMBED_UVX}"
  /usr/bin/plutil -lint "$PLIST" >/dev/null || die "plist failed lint: ${PLIST}"
}

validate_launchd_state() {
  emulate -L zsh
  if has_disabled_override "$STACK_LABEL"; then
    die "launchd has a disabled override for ${STACK_LABEL}; clear it explicitly before starting"
  fi
}

start_service() {
  emulate -L zsh
  hindsight_stack_require_current_user || exit 1
  validate_installed_files
  validate_launchd_state
  mkdir -p "${STATE_DIR}/logs" || die "failed to create log directory: ${STATE_DIR}/logs"

  bootout_if_loaded "$LEGACY_LABEL" || die "failed to unload ${LEGACY_LABEL}"

  if is_loaded "$STACK_LABEL"; then
    /bin/launchctl kickstart -k "$(service_name "$STACK_LABEL")" ||
      die "failed to restart ${STACK_LABEL}"
  else
    /bin/launchctl bootstrap "$(domain)" "$PLIST" ||
      die "failed to load ${STACK_LABEL} from ${PLIST}"
  fi
  is_loaded "$STACK_LABEL" || die "${STACK_LABEL} is not loaded after launchctl operation"

  if hindsight_stack_start_all; then
    retire_legacy_plist
    print -r -- "${STACK_LABEL} is loaded and Hindsight stack is healthy"
  else
    die "${STACK_LABEL} loaded, but Hindsight stack did not become healthy; see ${LOG_FILE}"
  fi
}

stop_service() {
  emulate -L zsh
  hindsight_stack_require_current_user || exit 1

  bootout_if_loaded "$STACK_LABEL" || die "failed to unload ${STACK_LABEL}"
  bootout_if_loaded "$LEGACY_LABEL" || die "failed to unload ${LEGACY_LABEL}"

  if [[ -x "$HINDSIGHT_EMBED_UVX" ]]; then
    hindsight_stack_stop_all || die "failed to stop Hindsight stack"
  fi
}

show_status() {
  emulate -L zsh
  hindsight_stack_require_current_user || exit 1
  validate_installed_files

  if is_loaded "$STACK_LABEL"; then
    print -r -- "launchd: loaded ($(service_name "$STACK_LABEL"))"
  else
    print -r -- "launchd: not loaded ($(service_name "$STACK_LABEL"))"
  fi

  if is_loaded "$LEGACY_LABEL"; then
    print -r -- "legacy launchd: loaded ($(service_name "$LEGACY_LABEL"))"
  else
    print -r -- "legacy launchd: not loaded ($(service_name "$LEGACY_LABEL"))"
  fi

  if [[ -e "$LEGACY_PLIST" ]]; then
    print -r -- "legacy plist: present (${LEGACY_PLIST})"
  else
    print -r -- "legacy plist: absent"
  fi

  if has_disabled_override "$STACK_LABEL"; then
    print -r -- "disabled override: true"
  else
    print -r -- "disabled override: false"
  fi

  print -r -- ""
  hindsight_stack_status_report
}

show_logs() {
  emulate -L zsh
  mkdir -p "${STATE_DIR}/logs" || die "failed to create log directory: ${STATE_DIR}/logs"
  touch "$LOG_FILE" || die "failed to open log file: ${LOG_FILE}"
  tail -n 80 -f "$LOG_FILE"
}

main() {
  emulate -L zsh
  setopt pipe_fail no_unset

  hindsight_stack_load_config
  local command="${1:-}"

  case "$command" in
    install|start)
      start_service
      ;;
    stop)
      stop_service
      ;;
    status)
      show_status
      ;;
    logs)
      show_logs
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      usage >&2
      die "unknown command: ${command}"
      ;;
  esac
}

main "$@"
