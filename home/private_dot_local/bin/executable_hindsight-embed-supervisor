#!/usr/bin/env zsh
set -euo pipefail

STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-$HOME/.local/lib/hindsight-embed-stack.zsh}"
STATE_DIR="${HINDSIGHT_EMBED_STATE_DIR:-$HOME/.local/state/hindsight-embed-launchd}"
LOG_DIR="${STATE_DIR}/logs"

mkdir -p "$LOG_DIR"
exec >>"${LOG_DIR}/supervisor.log" 2>&1

[[ -r "$STACK_LIB" ]] || {
  print -ru2 -- "hindsight-embed-supervisor: missing stack library at ${STACK_LIB}"
  exit 1
}

source_stack_lib() {
  emulate -L zsh

  . "$STACK_LIB" || {
    print -ru2 -- "hindsight-embed-supervisor: failed to source stack library at ${STACK_LIB}"
    exit 1
  }

  local required_function
  for required_function in \
    hindsight_stack_load_config \
    hindsight_stack_log \
    hindsight_stack_broker_status \
    hindsight_stack_fleet_profiles_csv \
    hindsight_stack_reconcile_once \
    hindsight_stack_require_current_user \
    hindsight_stack_require_runtime_helpers \
    hindsight_stack_require_tools \
    hindsight_stack_stop_all \
    hindsight_stack_validate_fleet; do
    if (( ! ${+functions[$required_function]} )); then
      print -ru2 -- "hindsight-embed-supervisor: invalid stack library at ${STACK_LIB}; missing ${required_function}"
      exit 1
    fi
  done
}

source_stack_lib

fail() {
  hindsight_stack_log "fatal: $*"
  exit 1
}

shutdown() {
  hindsight_stack_log "stopping stack"
  if hindsight_stack_stop_all; then
    exit 0
  fi
  hindsight_stack_log "stack stop failed"
  exit 1
}

main() {
  emulate -L zsh
  setopt err_exit pipe_fail no_unset

  hindsight_stack_load_config
  hindsight_stack_require_current_user || exit 1

  local poll_seconds="${HINDSIGHT_EMBED_POLL_SECONDS:-10}"

  hindsight_stack_require_tools || fail "missing required tools"
  hindsight_stack_require_runtime_helpers || fail "missing required helper runtime"
  hindsight_stack_validate_fleet || fail "invalid fleet configuration"

  trap shutdown INT TERM

  hindsight_stack_log "supervisor started pid=$$ profiles=$(hindsight_stack_fleet_profiles_csv) broker_socket=${HINDSIGHT_MEMORY_BROKER_SOCKET} control_port=${HINDSIGHT_EMBED_CONTROL_PORT}"

  while true; do
    hindsight_stack_reconcile_once || true
    sleep "$poll_seconds"
  done
}

main "$@"
