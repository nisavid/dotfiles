#!/usr/bin/env zsh
set -euo pipefail

STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-$HOME/.local/lib/hindsight-embed-stack.zsh}"
[[ -r "$STACK_LIB" ]] || {
  print -ru2 -- "hindsight-embed-supervisor: missing stack library at ${STACK_LIB}"
  exit 1
}
. "$STACK_LIB"

fail() {
  hindsight_stack_log "fatal: $*"
  exit 1
}

shutdown() {
  hindsight_stack_log "stopping stack"
  hindsight_stack_stop_all || true
  exit 0
}

main() {
  emulate -L zsh
  setopt pipe_fail no_unset

  hindsight_stack_load_config
  hindsight_stack_require_current_user || exit 1

  local poll_seconds="${HINDSIGHT_EMBED_POLL_SECONDS:-10}"
  local state_dir="${HINDSIGHT_EMBED_STATE_DIR:-$HOME/.local/state/hindsight-embed-launchd}"
  local log_dir="${state_dir}/logs"

  mkdir -p "$log_dir"
  exec >>"${log_dir}/supervisor.log" 2>&1

  hindsight_stack_require_tools || fail "missing required tools"

  trap shutdown INT TERM

  hindsight_stack_log "supervisor started pid=$$ profile=${HINDSIGHT_EMBED_PROFILE} control_port=${HINDSIGHT_EMBED_CONTROL_PORT} api_port=${HINDSIGHT_EMBED_API_PORT} ui_port=${HINDSIGHT_EMBED_UI_PORT}"

  while true; do
    hindsight_stack_reconcile_once || true
    sleep "$poll_seconds"
  done
}

main "$@"
