#!/usr/bin/env zsh
set -euo pipefail
umask 077

export HINDSIGHT_AGENTS_ROOT="${HINDSIGHT_AGENTS_ROOT:-{{ joinPath .chezmoi.homeDir .hindsight.agentsSourceDir }}}"
export HINDSIGHT_EMBED_STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-embed-stack.zsh" }}}"
export HINDSIGHT_EMBED_API_PYTHON="${HINDSIGHT_EMBED_API_PYTHON:-{{ joinPath .chezmoi.homeDir ".local/share/uv/tools/hindsight-api/bin/python" }}}"
export HINDSIGHT_EMBED_MIGRATION_HELPER="${HINDSIGHT_EMBED_MIGRATION_HELPER:-$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/libexec/hindsight-embed-single-bank-migrate.py}"
export HINDSIGHT_EMBED_SERVICE_COMMAND="${HINDSIGHT_EMBED_SERVICE_COMMAND:-{{ joinPath .chezmoi.homeDir ".local/bin/hindsight-embed-service" }}}"
export HINDSIGHT_BANK_ID="${HINDSIGHT_BANK_ID:-{{ .hindsight.bank }}}"
export HINDSIGHT_CLEANUP_SOURCE_BANKS="${HINDSIGHT_CLEANUP_SOURCE_BANKS:-claude_code,Engineering}"
export HINDSIGHT_CLEANUP_ARCHIVE_SOURCES="${HINDSIGHT_CLEANUP_ARCHIVE_SOURCES:-{{ joinPath .chezmoi.homeDir ".hindsight/profiles" }},{{ joinPath .chezmoi.homeDir (printf ".pg0/instances/hindsight-embed-%s" .hindsight.profile) }},{{ joinPath .chezmoi.homeDir ".pg0/instances/hindsight-embed-claude-code" }},{{ joinPath .chezmoi.homeDir ".pg0/instances/hindsight-embed-default" }},{{ joinPath .chezmoi.homeDir ".pg0/instances/hindsight-embed-" }}}"
export HINDSIGHT_CLEANUP_BANKS_URL="${HINDSIGHT_CLEANUP_BANKS_URL:-http://127.0.0.1:{{ .hindsight.apiPort }}/v1/default/banks}"
export HINDSIGHT_CLEANUP_ARCHIVE_ROOT="${HINDSIGHT_CLEANUP_ARCHIVE_ROOT:-{{ joinPath .chezmoi.homeDir ".hindsight/archives" }}}"
export HINDSIGHT_CLEANUP_LEGACY_PROFILES="${HINDSIGHT_CLEANUP_LEGACY_PROFILES:-claude-code,@default}"
export HINDSIGHT_CLEANUP_DELETE_PROFILES="${HINDSIGHT_CLEANUP_DELETE_PROFILES:-claude-code}"

exec "$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/bin/hindsight-embed-single-bank-cleanup" "$@"
