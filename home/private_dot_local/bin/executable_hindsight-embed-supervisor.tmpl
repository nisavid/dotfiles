#!/usr/bin/env zsh
set -euo pipefail
umask 077

export HINDSIGHT_AGENTS_ROOT="${HINDSIGHT_AGENTS_ROOT:-{{ joinPath .chezmoi.homeDir .hindsight.agentsSourceDir }}}"
export HINDSIGHT_EMBED_STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-embed-stack.zsh" }}}"
state_dir="${HINDSIGHT_EMBED_STATE_DIR:-{{ joinPath .chezmoi.homeDir ".local/state/hindsight-embed-launchd" }}}"
log_dir="$state_dir/logs"
/bin/mkdir -p "$log_dir"
/bin/chmod 700 "$state_dir" "$log_dir"
exec >>"$log_dir/supervisor.log" 2>&1

exec "$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/bin/hindsight-embed-supervisor" "$@"
