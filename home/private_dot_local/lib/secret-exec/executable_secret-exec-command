#!/usr/bin/env zsh

[[ -o xtrace ]] && unsetopt xtrace
set -euo pipefail
typeset -gr SECRET_EXEC_COMMAND_NAME=${0:t}
typeset -gr SECRET_EXEC_SHIM_DIR=${0:h:A}
typeset -gr SECRET_EXEC_DISPATCHER=${0:A}

die() {
  print -u2 -r -- "secret-exec-command: $1"
  exit 1
}

main() {
  emulate -L zsh
  setopt local_options pipe_fail

  local command_name=$SECRET_EXEC_COMMAND_NAME
  local shim_dir=$SECRET_EXEC_SHIM_DIR
  local mapping_file=${XDG_CONFIG_HOME:-$HOME/.config}/secret-exec/commands.env
  local launcher=$HOME/.local/bin/secret-exec
  local mapping_pattern='^([A-Za-z0-9][A-Za-z0-9_.+-]*)=([A-Za-z0-9][A-Za-z0-9_.-]*)$'
  local line mapped_command mapped_profile
  local profile=''
  local -A command_profiles

  [[ -f $mapping_file && ! -L $mapping_file && -r $mapping_file ]] || \
    die 'command mapping must be a readable regular file'
  [[ -f $launcher && ! -L $launcher && -r $launcher && -x $launcher ]] || \
    die 'secret-exec launcher is unavailable'

  while IFS= read -r line || [[ -n $line ]]; do
    [[ -z $line || $line == \#* ]] && continue
    [[ $line =~ $mapping_pattern ]] || die 'invalid command mapping'
    mapped_command=$match[1]
    mapped_profile=$match[2]
    (( ! ${+command_profiles[$mapped_command]} )) || \
      die "duplicate mapping for $mapped_command"
    command_profiles[$mapped_command]=$mapped_profile
  done < "$mapping_file"

  profile=${command_profiles[$command_name]:-}
  [[ -n $profile ]] || die "no profile is mapped to $command_name"

  local directory candidate
  local target=''
  local -a search_directories
  search_directories=("${(@s.:.)PATH}")
  for directory in "${search_directories[@]}"; do
    [[ -n $directory ]] || directory=.
    [[ ${directory:A} != $shim_dir ]] || continue
    candidate=$directory/$command_name
    [[ -f $candidate && -x $candidate ]] || continue
    [[ ${candidate:A} != $SECRET_EXEC_DISPATCHER ]] || continue
    target=${candidate:A}
    break
  done

  [[ -n $target ]] || die "no executable target found for $command_name"
  exec "$launcher" "$profile" -- "$target" "$@"
}

main "$@"
