# Ivan's machine bindings for the reusable Hindsight stack in nisavid/agents.

typeset -gx HINDSIGHT_AGENTS_ROOT="${HINDSIGHT_AGENTS_ROOT:-{{ joinPath .chezmoi.homeDir .hindsight.agentsSourceDir }}}"
typeset -gx HINDSIGHT_EMBED_STACK_LIB="${HINDSIGHT_EMBED_STACK_LIB:-{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-embed-stack.zsh" }}}"
typeset -gx HINDSIGHT_EMBED_UVX="${HINDSIGHT_EMBED_UVX:-{{ joinPath .chezmoi.homeDir ".local/bin/uvx" }}}"
typeset -gx HINDSIGHT_EMBED_CONTROL_PORT="${HINDSIGHT_EMBED_CONTROL_PORT:-{{ .hindsight.controlPort }}}"
typeset -gx HINDSIGHT_EMBED_CONTROL_HOSTNAME="${HINDSIGHT_EMBED_CONTROL_HOSTNAME:-127.0.0.1}"
typeset -gx HINDSIGHT_EMBED_PRIMARY_PROFILE="${HINDSIGHT_EMBED_PRIMARY_PROFILE:-${HINDSIGHT_EMBED_PROFILE:-{{ .hindsight.profile }}}}"
typeset -gx HINDSIGHT_EMBED_FLEET_PROFILES="${HINDSIGHT_EMBED_FLEET_PROFILES:-{{ .hindsight.profile }}}"
typeset -g HINDSIGHT_EMBED_PROFILE="${HINDSIGHT_EMBED_PROFILE:-$HINDSIGHT_EMBED_PRIMARY_PROFILE}"
typeset -gx HINDSIGHT_EMBED_API_BASE_PORT="${HINDSIGHT_EMBED_API_BASE_PORT:-{{ .hindsight.apiPort }}}"
typeset -gx HINDSIGHT_EMBED_UI_BASE_PORT="${HINDSIGHT_EMBED_UI_BASE_PORT:-{{ .hindsight.uiPort }}}"
typeset -g HINDSIGHT_EMBED_API_PORT="${HINDSIGHT_EMBED_API_PORT:-$HINDSIGHT_EMBED_API_BASE_PORT}"
typeset -g HINDSIGHT_EMBED_UI_PORT="${HINDSIGHT_EMBED_UI_PORT:-$HINDSIGHT_EMBED_UI_BASE_PORT}"
typeset -gx HINDSIGHT_EMBED_UI_HOSTNAME="${HINDSIGHT_EMBED_UI_HOSTNAME:-{{ .hindsight.uiHostname }}}"
typeset -gx HINDSIGHT_EMBED_PYTHON="${HINDSIGHT_EMBED_PYTHON:-{{ joinPath .chezmoi.homeDir ".local/share/uv/tools/hindsight-embed/bin/python" }}}"
typeset -gx HINDSIGHT_EMBED_STOP_HELPER="${HINDSIGHT_EMBED_STOP_HELPER:-$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/libexec/hindsight-embed-stop-profile-services.py}"
typeset -g HINDSIGHT_EMBED_CONTROL_SERVER="${HINDSIGHT_EMBED_CONTROL_SERVER:-$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/libexec/hindsight-embed-control-server.py}"
typeset -g HINDSIGHT_EMBED_LLM_RUNTIME="${HINDSIGHT_EMBED_LLM_RUNTIME:-{{ joinPath .chezmoi.homeDir ".local/lib/hindsight-runtime" }}}"
typeset -gx PYTHONPATH="$HINDSIGHT_EMBED_LLM_RUNTIME"
typeset -gx HINDSIGHT_MEMORY_CLI="${HINDSIGHT_MEMORY_CLI:-$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/bin/hindsight-memory}"
typeset -gx HINDSIGHT_MEMORY_STATE_DIR="${HINDSIGHT_MEMORY_STATE_DIR:-{{ joinPath .chezmoi.homeDir ".local/state/hindsight-memory" }}}"
typeset -gx HINDSIGHT_MEMORY_BROKER_SOCKET="${HINDSIGHT_MEMORY_BROKER_SOCKET:-$HINDSIGHT_MEMORY_STATE_DIR/broker.sock}"
typeset -gx HINDSIGHT_EMBED_STATE_DIR="${HINDSIGHT_EMBED_STATE_DIR:-{{ joinPath .chezmoi.homeDir ".local/state/hindsight-embed-launchd" }}}"
typeset -g HINDSIGHT_EMBED_PROFILE_SLOT_DIR="${HINDSIGHT_EMBED_PROFILE_SLOT_DIR:-$HINDSIGHT_EMBED_STATE_DIR/profile-slots}"
typeset -g HINDSIGHT_EMBED_DESIRED_STATE_DIR="${HINDSIGHT_EMBED_DESIRED_STATE_DIR:-$HINDSIGHT_EMBED_STATE_DIR/desired}"
typeset -gx HINDSIGHT_EMBED_AUTOSTART_DAEMON="${HINDSIGHT_EMBED_AUTOSTART_DAEMON:-{{ if .hindsight.autostartDaemon }}true{{ else }}false{{ end }}}"
typeset -gx HINDSIGHT_EMBED_AUTOSTART_UI="${HINDSIGHT_EMBED_AUTOSTART_UI:-{{ if .hindsight.autostartUi }}true{{ else }}false{{ end }}}"
typeset -g HINDSIGHT_EMBED_CONTROL_WAIT_SECONDS="${HINDSIGHT_EMBED_CONTROL_WAIT_SECONDS:-30}"
typeset -g HINDSIGHT_EMBED_DAEMON_WAIT_SECONDS="${HINDSIGHT_EMBED_DAEMON_WAIT_SECONDS:-300}"
typeset -g HINDSIGHT_EMBED_SIDECAR_WAIT_SECONDS="${HINDSIGHT_EMBED_SIDECAR_WAIT_SECONDS:-120}"
typeset -g HINDSIGHT_EMBED_UI_WAIT_SECONDS="${HINDSIGHT_EMBED_UI_WAIT_SECONDS:-60}"
typeset -g HINDSIGHT_MEMORY_BROKER_WAIT_SECONDS="${HINDSIGHT_MEMORY_BROKER_WAIT_SECONDS:-30}"
typeset -g HINDSIGHT_EMBED_STOP_WAIT_SECONDS="${HINDSIGHT_EMBED_STOP_WAIT_SECONDS:-30}"
typeset -g HINDSIGHT_EMBED_START_COOLDOWN_SECONDS="${HINDSIGHT_EMBED_START_COOLDOWN_SECONDS:-20}"
typeset -g HINDSIGHT_EMBED_LIFECYCLE_COMMAND_TIMEOUT_SECONDS="${HINDSIGHT_EMBED_LIFECYCLE_COMMAND_TIMEOUT_SECONDS:-300}"

typeset -g HINDSIGHT_COMMON_STACK_LIB="$HINDSIGHT_AGENTS_ROOT/tooling/hindsight/lib/hindsight-embed-stack.zsh"
if [[ ! -r "$HINDSIGHT_COMMON_STACK_LIB" ]]; then
  print -ru2 -- "hindsight-embed-stack: missing nisavid/agents stack library at ${HINDSIGHT_COMMON_STACK_LIB}"
  return 1
fi
. "$HINDSIGHT_COMMON_STACK_LIB"
