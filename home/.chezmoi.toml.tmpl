encryption = "age"

[age]
    command = "age"
    identity = {{ (joinPath .chezmoi.homeDir ".config/age/key.txt") | quote }}
    recipient = ""

{{ `[merge]
command = "bash"
args = [
  "-c",
  "cp {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} && cursor --new-window --wait --merge {{ .Destination | quote }} {{ .Target | quote }} {{ printf \"%s.base\" .Target | quote }} {{ .Source | quote }}",
]` }}
