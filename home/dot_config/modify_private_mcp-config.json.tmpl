#!/usr/bin/env bash
set -euo pipefail

command={{ joinPath .chezmoi.homeDir ".local/bin/secret-exec" | quote }}

jq --arg command "$command" '
  .mcpServers = (.mcpServers // {}) |
  .mcpServers.firecrawl = ((.mcpServers.firecrawl // {}) + {
    type: "stdio",
    command: $command,
    args: ["firecrawl", "--", "npx", "-y", "firecrawl-mcp"]
  }) |
  del(
    .mcpServers.firecrawl.url,
    .mcpServers.firecrawl.env,
    .mcpServers.firecrawl.env_vars,
    .mcpServers.firecrawl.headers,
    .mcpServers.firecrawl.http_headers,
    .mcpServers.firecrawl.bearer_token_env_var
  )
' < /dev/stdin
