{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:example:hindsight-memory:benchmark-case:v1",
  "title": "Hindsight Memory Retrieval Benchmark Case",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "case_id",
    "query",
    "relevance",
    "must_recall",
    "must_not_return"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "case_id": {"type": "string", "minLength": 1},
    "query": {"type": "string", "minLength": 1},
    "relevance": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "integer", "minimum": 1, "maximum": 3}
    },
    "must_recall": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "must_not_return": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
